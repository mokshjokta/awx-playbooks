# Managed by Ansible. Company-wide DNS/search settings.
network:
  version: 2
  ethernets:
    all-en:
      match:
        name: "en*"
      dhcp4: true
      dhcp4-overrides:
        use-dns: false
      nameservers:
        addresses:
{% for s in dns_servers %}
          - {{ s }}
{% endfor %}
        search:
{% for d in dns_search %}
          - {{ d }}
{% endfor %}
