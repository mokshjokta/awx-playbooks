#!/usr/bin/env bash
# Managed by Ansible - backup critical configs
set -euo pipefail
STAMP=$(date +%Y%m%d-%H%M%S)
DEST="{{ backup_dest }}/backup-${STAMP}.tar.gz"
tar czf "$DEST" \
{% for p in backup_paths %}
  {{ p }} \
{% endfor %}
  2>/dev/null || true
# keep last 7 backups
ls -1t {{ backup_dest }}/backup-*.tar.gz | tail -n +8 | xargs -r rm -f
logger -t softage-backup "backup written to $DEST"
